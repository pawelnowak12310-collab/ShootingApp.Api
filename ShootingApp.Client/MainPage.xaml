<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ShootingApp.Client.Models"
             x:Class="ShootingApp.Client.MainPage">

    <VerticalStackLayout Spacing="20" Padding="30">
        <Label Text="Statystyki Rzutów" FontSize="24" HorizontalOptions="Center"/>
        <Label Text="{Binding ShotsTaken, StringFormat='Oddane: {0}'}" FontSize="20" HorizontalOptions="Center"/>
        <Label Text="{Binding ShotsMade, StringFormat='Trafione: {0}'}" FontSize="20" HorizontalOptions="Center"/>

        <Button Text="Trafiony" Command="{Binding AddMakeCommand}" BackgroundColor="Green" TextColor="White"/>
        <Button Text="Pudło" Command="{Binding AddMissCommand}" BackgroundColor="Red" TextColor="White"/>
        <Button Text="Zapisz sesję" Command="{Binding SaveToDatabaseCommand}" BackgroundColor="Blue" TextColor="White"/>

        <Label Text="Historia treningów:" FontAttributes="Bold" FontSize="18" />
        <CollectionView ItemsSource="{Binding Sessions}" HeightRequest="300">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ShootingSession">
                    <Frame Margin="0,5" Padding="10" BackgroundColor="#2c2c2c">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="{Binding Date, StringFormat='{0:dd.MM HH:mm}'}" TextColor="White" />
                            <Label Text="{Binding ShotsTaken, StringFormat='Oddane: {0}'}" TextColor="LightGray" />
                            <Label Text="{Binding ShotsMade, StringFormat='Trafione: {0}'}" TextColor="GreenYellow" />
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
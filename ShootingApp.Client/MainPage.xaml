<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ShootingApp.Client.MainPage">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
        <Label Text="Statystyki Rzutów" FontSize="24" HorizontalOptions="Center"/>

        <Label Text="{Binding ShotsTaken, StringFormat='Oddane: {0}'}" FontSize="20" HorizontalOptions="Center"/>
        <Label Text="{Binding ShotsMade, StringFormat='Trafione: {0}'}" FontSize="20" HorizontalOptions="Center"/>

        <Button Text="Trafiony" Command="{Binding AddMakeCommand}" BackgroundColor="Green" TextColor="White"/>
        <Button Text="Pudło" Command="{Binding AddMissCommand}" BackgroundColor="Red" TextColor="White"/>
        <Button Text="Zapisz sesję" Command="{Binding SaveToDatabaseCommand}" BackgroundColor="Blue" TextColor="White"/>
    </VerticalStackLayout>
</ContentPage>